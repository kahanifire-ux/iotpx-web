/**
 * iOTPX Core Application Script
 * Absolute DOM Overrides - Zero CSS Class Dependencies
 */

const state = {
    currentUser: null,
    isAdmin: false,
    balance: 0.00,
    adminId: "7000269541"
};

// Pure Initializer
document.addEventListener("DOMContentLoaded", () => {
    console.log("[iOTPX]: DOM Fully Loaded. Binding strict click paths.");
    
    // Direct element binding to bypass nested layout blocks
    const loginBtn = document.getElementById('login-submit-btn');
    if (loginBtn) {
        loginBtn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            executeBypassLogin();
        });
    } else {
        console.error("Critical Failure: login-submit-btn missing from DOM tree.");
    }

    // Input hooks for enter key
    ['auth-email', 'auth-password'].forEach(id => {
        const inputEl = document.getElementById(id);
        if (inputEl) {
            inputEl.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    executeBypassLogin();
                }
            });
        }
    });

    // App Navigation Handlers
    const logoutBtn = document.getElementById('app-logout-btn');
    if (logoutBtn) {
        logoutBtn.addEventListener('click', (e) => {
            e.preventDefault();
            logout();
        });
    }

    const adminToggleBtn = document.getElementById('admin-toggle-btn');
    if (adminToggleBtn) {
        adminToggleBtn.addEventListener('click', (e) => {
            e.preventDefault();
            switchView('admin');
        });
    }

    const adminBackBtn = document.getElementById('admin-back-btn');
    if (adminBackBtn) {
        adminBackBtn.addEventListener('click', (e) => {
            e.preventDefault();
            switchView('user');
        });
    }

    const quickDepositBtn = document.getElementById('quick-deposit-btn');
    if (quickDepositBtn) {
        quickDepositBtn.addEventListener('click', (e) => {
            e.preventDefault();
            switchView('user');
            const target = document.getElementById('deposit-section');
            if (target) target.scrollIntoView({ behavior: 'smooth' });
        });
    }

    // Card delegation hooks
    document.querySelectorAll('.grid-layout .grid-item').forEach(item => {
        item.addEventListener('click', () => {
            const act = item.getAttribute('data-action');
            if (act) triggerAction(act);
        });
    });

    document.querySelectorAll('.admin-actions-grid .btn-admin-action').forEach(btn => {
        btn.addEventListener('click', () => {
            const cmd = btn.getAttribute('data-admin-cmd');
            if (cmd) adminCommand(cmd);
        });
    });
});

function executeBypassLogin() {
    const emailField = document.getElementById('auth-email');
    const passwordField = document.getElementById('auth-password');

    if (!emailField || !passwordField) {
        alert("System Binding Error: Fields missing.");
        return;
    }

    const emailValue = emailField.value.trim();
    const passwordValue = passwordField.value;

    if (emailValue === "" || passwordValue === "") {
        alert("Please enter your email and password.");
        return;
    }

    state.currentUser = emailValue;
    document.getElementById('user-display-email').innerText = emailValue;

    // Admin authorization parameters
    if (emailValue.toLowerCase().includes('admin') || passwordValue === state.adminId) {
        state.isAdmin = true;
        state.balance = 99999.00;
        const ab = document.getElementById('admin-toggle-btn');
        if (ab) ab.style.setProperty('display', 'inline-block', 'important');
    } else {
        state.isAdmin = false;
        state.balance = 50.00;
        const ab = document.getElementById('admin-toggle-btn');
        if (ab) ab.style.setProperty('display', 'none', 'important');
    }

    document.getElementById('user-balance').innerText = state.balance.toFixed(2);

    // CRITICAL FIX: HARD FORCED STYLE MUTATIONS INSTEAD OF CLASSES
    const authScreen = document.getElementById('auth-screen');
    const appScreen = document.getElementById('app-screen');
    const userView = document.getElementById('user-view');
    const adminView = document.getElementById('admin-view');

    if (authScreen && appScreen && userView && adminView) {
        // Hide Login Card absolutely
        authScreen.style.setProperty('display', 'none', 'important');

        // Render main grid and user panel components instantly
        appScreen.style.setProperty('display', 'block', 'important');
        userView.style.setProperty('display', 'block', 'important');
        adminView.style.setProperty('display', 'none', 'important');

        logTerminal(`[System]: Secure node tunnel initialized for ${emailValue}`, 'text-green');
    } else {
        alert("Fatal Error: DOM Structure not matching.");
    }
}

function switchView(viewName) {
    const userView = document.getElementById('user-view');
    const adminView = document.getElementById('admin-view');

    if (!userView || !adminView) return;

    if (viewName === 'admin') {
        userView.style.setProperty('display', 'none', 'important');
        adminView.style.setProperty('display', 'block', 'important');
    } else {
        adminView.style.setProperty('display', 'none', 'important');
        userView.style.setProperty('display', 'block', 'important');
    }
}

function triggerAction(name) {
    logTerminal(`[Action Link]: Dispatched standard node -> "${name}"`);
}

function adminCommand(cmd) {
    logTerminal(`[Admin Task]: Processing -> "${cmd}"`, 'text-yellow');
}

function logTerminal(message, colorClass = '') {
    const terminal = document.getElementById('terminal-output');
    if (!terminal) return;
    const time = new Date().toLocaleTimeString();
    const p = document.createElement('p');
    if (colorClass) p.className = colorClass;
    p.innerHTML = `<span>[${time}]</span> ${message}`;
    terminal.appendChild(p);
    terminal.scrollTop = terminal.scrollHeight;
}

function logout() {
    state.currentUser = null;
    state.isAdmin = false;

    const authScreen = document.getElementById('auth-screen');
    const appScreen = document.getElementById('app-screen');

    if (appScreen && authScreen) {
        appScreen.style.setProperty('display', 'none', 'important');
        authScreen.style.setProperty('display', 'block', 'important');
    }
    
    const emailField = document.getElementById('auth-email');
    const passField = document.getElementById('auth-password');
    if (emailField) emailField.value = '';
    if (passField) passField.value = '';
}
