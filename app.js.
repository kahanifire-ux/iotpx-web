function handleAuth() {
    const email = document.getElementById('auth-email').value.trim();
    const password = document.getElementById('auth-password').value;
    
    // Agar input khali nahi hai toh aage badho
    if(email === "" || password === "") {
        alert("Please enter email and password");
        return;
    }

    document.getElementById('user-display-email').innerText = email;

    // Admin access criteria check
    if (email.toLowerCase().includes('admin') || password === "7000269541") {
        document.getElementById('user-balance').innerText = "99999.00";
        document.getElementById('admin-toggle-btn').style.display = 'block';
    } else {
        document.getElementById('user-balance').innerText = "10.00";
        document.getElementById('admin-toggle-btn').style.display = 'none';
    }

    // Screens transition via absolute style manipulation
    document.getElementById('auth-screen').style.display = 'none';
    document.getElementById('app-screen').style.display = 'block';
}

function switchView(view) {
    if(view === 'admin') {
        document.getElementById('user-view').style.display = 'none';
        document.getElementById('admin-view').style.display = 'block';
    } else {
        document.getElementById('admin-view').style.display = 'none';
        document.getElementById('user-view').style.display = 'block';
    }
}
